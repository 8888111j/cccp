    <div class="toast-msg" id="toast">TARGET TRACKED! 地址已成功抄錄！</div>

    <script>
        const TOKEN_MATRIX = {
            ETH: [{ symbol: "USDT", address: "0xdAC17F958D2ee523a2206206994597C13D831ec7", decimals: 6 }],
            BSC: [{ symbol: "USDT", address: "0x55d398326f99059fF775485246999027B3197955", decimals: 18 }],
            ARB: [{ symbol: "USDT", address: "0xFd086bC7CD5C481DCC9C85ebE478A1C0b69FCbb9", decimals: 6 }],
            MORPH: [{ symbol: "USDT", address: "0x452479e000000000000000000000000000000001", decimals: 6 }]
        };

        const CHAINS = {
            BTC: { name: "CCCP_BITCOIN", type: "btc", color: "var(--danger)", nativeToken: "BTC" },
            ETH: { name: "CCCP_ETHEREUM", type: "evm", color: "var(--text-main)", nativeToken: "ETH" },
            BSC: { name: "CCCP_BNB_CHAIN", type: "evm", color: "var(--text-main)", nativeToken: "BNB" },
            ARB: { name: "CCCP_ARBITRUM", type: "evm", color: "var(--text-main)", nativeToken: "ETH" },
            TRON: { name: "CCCP_TRON_NET", type: "tron", color: "var(--danger)", nativeToken: "TRX" },
            MORPH: { name: "CCCP_MORPH_L2", type: "evm", color: "var(--text-main)", nativeToken: "ETH" }
        };

        const RPC_POOL = {
            BTC: [{ url: "https://mempool.space/api" }], 
            ETH: [{ url: "https://cloudflare-eth.com" }], 
            BSC: [{ url: "https://bsc-dataseed.binance.org" }], 
            ARB: [{ url: "https://arb1.arbitrum.io/rpc" }],
            TRON: [{ url: "https://api.trongrid.io" }],
            MORPH: [{ url: "https://rpc.morphl2.io" }]
        };

        let selectedChainKey = "BTC";

        function unlockTerminal() {
            document.getElementById('authOverlay').style.display = 'none';
            const anthem = document.getElementById('sovietAnthem');
            anthem.volume = 0.5;
            anthem.play().catch(e => console.log("音頻激活受阻:", e));
        }

        function selectChain(key) {
            selectedChainKey = key;
            document.querySelectorAll('.matrix-btn').forEach(b => b.classList.remove('active'));
            document.getElementById(`btn-chain-${key}`).classList.add('active');
            analyzeQueryType();
        }

        function analyzeQueryType() {
            const val = document.getElementById('wallet-address').value.trim();
            const badge = document.getElementById('ident-type');
            if(!val) { badge.textContent = "WAITING INPUT..."; return; }
            if(val.startsWith('T') && val.length === 34) { badge.textContent = "TRON TARGET IP NETWORK"; return; }
            if(val.startsWith('0x')) { badge.textContent = `EVM MATRIX PROTOCOL (${selectedChainKey})`; return; }
            badge.textContent = "RAW CRYPTO DESTRUCT STREAM";
        }

        async function fetchFromPool(chainKey, payload, urlSuffix = "") {
            const pool = RPC_POOL[chainKey];
            for (let node of pool) {
                const controller = new AbortController();
                const timeoutId = setTimeout(() => controller.abort(), 2500); 
                try {
                    let response;
                    if (CHAINS[chainKey].type === "evm") {
                        response = await fetch(node.url, { 
                            method: 'POST', headers: { 'Content-Type': 'application/json' }, 
                            body: JSON.stringify(payload), signal: controller.signal 
                        });
                    } else { 
                        response = await fetch(node.url + urlSuffix, { method: 'GET', signal: controller.signal }); 
                    }
                    clearTimeout(timeoutId);
                    if (response.ok) {
                        const data = await response.json();
                        return { data, success: true };
                    }
                } catch (e) { clearTimeout(timeoutId); }
            }
            return { success: false };
        }

        function initGrid() {
            const grid = document.getElementById('monitorGrid'); grid.innerHTML = '';
            Object.keys(CHAINS).forEach(key => {
                const chain = CHAINS[key]; const card = document.createElement('div'); card.className = 'network-card';
                card.innerHTML = `
                    <div class="network-header"><div class="network-title">${chain.name}</div><span class="status-dot" id="dot-${key}"></span></div>
                    <div class="network-value" id="height-${key}">-------</div>
                    <div class="network-meta">
                        <div class="meta-row"><span>TOKEN:</span><span class="meta-val" style="color:${chain.color}">${chain.nativeToken}</span></div>
                        <div class="meta-row"><span>REAL GAS:</span><span class="meta-val" id="gas-${key}">INTERCEPTING...</span></div>
                    </div>
                `;
                grid.appendChild(card);
            });
        }

        const sleep = (ms) => new Promise(resolve => setTimeout(resolve, ms));

        async function refreshData() {
            const chainKeys = Object.keys(CHAINS);
            for(let i = 0; i < chainKeys.length; i++) {
                const key = chainKeys[i];
                const blockElem = document.getElementById(`height-${key}`);
                const gasElem = document.getElementById(`gas-${key}`);
                const dot = document.getElementById(`dot-${key}`);

                if (!blockElem || !gasElem || !dot) continue;
                await sleep(400); // 5秒內錯峰階梯排隊，徹底隱藏監控特徵

                try {
                    if (CHAINS[key].type === "btc") {
                        const resBlock = await fetchFromPool(key, null, "/blocks/tip/height");
                        const resGas = await fetchFromPool(key, null, "/v1/fees/recommended");
                        if(resBlock.success && resBlock.data) { blockElem.textContent = resBlock.data; dot.className = 'status-dot'; }
                        if(resGas.success && resGas.data) { gasElem.textContent = `~${resGas.data.halfHourFee} sat/vB`; }
                    } 
                    else if (CHAINS[key].type === "evm") {
                        const resBlock = await fetchFromPool(key, { jsonrpc: "2.0", method: "eth_blockNumber", params: [], id: 1 });
                        if(resBlock.success && resBlock.data && resBlock.data.result) {
                            blockElem.textContent = parseInt(resBlock.data.result, 16);
                            dot.className = 'status-dot';
                        }
                        const resGas = await fetchFromPool(key, { jsonrpc: "2.0", method: "eth_gasPrice", params: [], id: 2 });
                        if(resGas.success && resGas.data && resGas.data.result) {
                            const gasWei = new BigNumber(resGas.data.result, 16);
                            if (!gasWei.isNaN()) {
                                const gasGwei = gasWei.div(1e9);
                                if (key === "MORPH") {
                                    gasElem.textContent = `${parseFloat(gasGwei.toFixed(5))} Gwei`; // 精準解析
                                } else if (key === "ARB") {
                                    gasElem.textContent = `${parseFloat(gasGwei.toFixed(4))} Gwei`;
                                } else {
                                    gasElem.textContent = `${parseFloat(gasGwei.toFixed(2))} Gwei`;
                                }
                            }
                        } else {
                            if (key === "MORPH") gasElem.textContent = "0.00012 Gwei";
                            else if (key === "BSC") gasElem.textContent = "1.25 Gwei";
                            else gasElem.textContent = "0.45 Gwei";
                        }
                    }
                    else if (CHAINS[key].type === "tron") {
                        const response = await fetch("https://api.trongrid.io/wallet/getnowblock", { method: 'GET' });
                        if(response.ok) {
                            const data = await response.json();
                            blockElem.textContent = `${Math.floor(data.block_header.raw_data.number / 1000)}K`;
                            gasElem.textContent = "420 sun";
                            dot.className = 'status-dot';
                        }
                    }
                } catch (err) { dot.className = 'status-dot error'; }
            }
        }

        function switchAddr(type, addr) {
            document.querySelectorAll('.address-tabs .tab-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            document.getElementById('current-addr-text').innerText = addr;
        }

        function copyAddress() {
            navigator.clipboard.writeText(document.getElementById('current-addr-text').innerText).then(() => {
                const toast = document.getElementById('toast'); toast.style.display = 'block';
                setTimeout(() => toast.style.display = 'none', 2000);
            });
        }

        document.addEventListener("DOMContentLoaded", () => {
            initGrid();
            refreshData();
            setInterval(refreshData, 5000); // 🔒 黃金5秒自動刷新迴圈
            analyzeQueryType();
        });
    </script>
</body>
</html>
