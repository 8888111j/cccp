<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KGB - TOP SECRET BLOCKCHAIN MONITORING SYSTEM</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bignumber.js/9.1.2/bignumber.min.js"></script>
    
    <style>
        :root {
            --bg: #050806; /* 絕密特工暗黑綠 */
            --card-bg: #0a110c; /* 軍用終端機卡片色 */
            --text-main: #00ff66; /* CRT 顯像管經典亮綠 */
            --text-muted: #559966;
            --primary: #00ff55;
            --success: #00ff66;
            --warning: #ffcc00;
            --danger: #ff0033; /* 警報紅 */
            --border: #005522; /* 鐵絲網綠邊框 */
            --neon-glow: 0 0 10px rgba(0, 255, 102, 0.5);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background-color: var(--bg); color: var(--text-main);
            font-family: 'Share Tech Mono', monospace;
            padding-bottom: 50px; line-height: 1.5;
            letter-spacing: 1px;
        }

        /* 🔒 克格勃強制作戰解鎖彈窗（繞過瀏覽器音頻限制） */
        .auth-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: #000; z-index: 9999; display: flex;
            flex-direction: column; align-items: center; justify-content: center;
            border: 4px solid var(--danger);
        }
        .auth-box {
            text-align: center; max-width: 500px; padding: 30px;
            border: 2px solid var(--text-main); background: var(--card-bg);
            box-shadow: 0 0 30px rgba(0,255,102,0.2);
        }
        .auth-title { color: var(--danger); font-size: 2rem; font-weight: bold; margin-bottom: 15px; text-shadow: 0 0 10px rgba(255,0,51,0.5); }
        .auth-btn {
            background: transparent; border: 2px solid var(--text-main); color: var(--text-main);
            padding: 12px 30px; font-size: 1.2rem; font-family: 'Share Tech Mono', monospace;
            cursor: pointer; font-weight: bold; margin-top: 20px; transition: all 0.3s;
        }
        .auth-btn:hover { background: var(--text-main); color: #000; box-shadow: var(--neon-glow); }

        /* 主體 UI */
        .navbar {
            display: flex; justify-content: space-between; align-items: center;
            padding: 15px 5%; background-color: var(--card-bg); border-bottom: 2px solid var(--border);
            box-shadow: var(--neon-glow);
        }
        .navbar h1 { font-size: 1.5rem; text-shadow: var(--neon-glow); }
        .system-status {
            display: inline-flex; align-items: center; font-size: 0.85rem; color: var(--success);
            background: rgba(0, 255, 102, 0.1); padding: 4px 10px; border: 1px solid var(--border);
        }
        .system-status i { margin-right: 5px; animation: blink 1s infinite; }

        .container { max-width: 1200px; margin: 20px auto; padding: 0 15px; display: flex; flex-direction: column; gap: 20px; }
        
        /* 跑馬燈 */
        .marquee-wrapper {
            background-color: var(--card-bg); border: 2px solid var(--border);
            overflow: hidden; min-height: 52px; box-shadow: inset 0 0 10px rgba(0,255,102,0.2);
        }

        /* 數據網格 */
        .network-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 15px; }
        .network-card { background-color: var(--card-bg); border: 2px solid var(--border); padding: 15px; position: relative; }
        .network-card::before {
            content: "STATE MONITOR"; position: absolute; top: -10px; left: 10px;
            background: var(--bg); padding: 0 5px; font-size: 0.65rem; color: var(--text-muted);
        }
        .network-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
        .network-title { font-size: 1.1rem; font-weight: bold; }
        .status-dot { width: 10px; height: 10px; background-color: var(--success); display: inline-block; box-shadow: var(--neon-glow); }
        .status-dot.error { background-color: var(--danger); animation: blink 1.5s infinite; }
        
        @keyframes blink { 0% { opacity: 1; } 50% { opacity: 0.2; } 100% { opacity: 1; } }
        
        .network-value { font-size: 1.8rem; font-weight: bold; color: var(--text-main); margin-bottom: 10px; text-shadow: var(--neon-glow); }
        .network-meta { display: flex; flex-direction: column; gap: 4px; font-size: 0.85rem; color: var(--text-muted); border-top: 1px solid var(--border); padding-top: 8px; }
        .meta-row { display: flex; justify-content: space-between; }
        .meta-val { color: var(--text-main); }

        /* 解構模組 */
        .module-card { background-color: var(--card-bg); border: 2px solid var(--border); padding: 22px; position: relative; }
        .module-header { font-size: 1.3rem; font-weight: bold; margin-bottom: 15px; border-bottom: 2px solid var(--border); padding-bottom: 10px; color: var(--danger); text-shadow: 0 0 5px rgba(255,0,0,0.3); }
        .module-desc { font-size: 0.9rem; color: var(--text-muted); margin-bottom: 15px; }
        
        .chain-matrix-selector { display: grid; grid-template-columns: repeat(auto-fit, minmax(110px, 1fr)); gap: 8px; margin-bottom: 15px; }
        .matrix-btn {
            background: #070d09; border: 1px solid var(--border); color: var(--text-main); padding: 10px 5px;
            cursor: pointer; text-align: center; font-family: 'Share Tech Mono', monospace; font-size: 0.9rem; transition: all 0.2s;
        }
        .matrix-btn:hover, .matrix-btn.active { border-color: var(--primary); background: rgba(0, 255, 102, 0.15); box-shadow: var(--neon-glow); }
        .matrix-btn span.chain-lbl { font-size: 0.7rem; color: var(--text-muted); display: block; }

        .query-box { display: flex; flex-direction: column; gap: 12px; }
        .input-group { display: flex; gap: 8px; }
        input { background-color: #020403; border: 2px solid var(--border); color: var(--text-main); padding: 10px 14px; font-size: 1rem; outline: none; flex: 1; font-family: 'Share Tech Mono', monospace; }
        input:focus { border-color: var(--primary); box-shadow: var(--neon-glow); }
        .btn-action { background-color: transparent; border: 2px solid var(--danger); color: var(--danger); padding: 11px 20px; font-weight: bold; cursor: pointer; font-size: 1rem; font-family: 'Share Tech Mono', monospace; transition: all 0.2s; }
        .btn-action:hover { background: var(--danger); color: #000; box-shadow: 0 0 10px rgba(255,0,53,0.5); }

        /* 終端機控制台 */
        .terminal-container { background-color: #020503; border: 2px solid var(--danger); padding: 15px; font-size: 0.95rem; color: #00ff55; margin-top: 15px; display: none; box-shadow: inset 0 0 15px rgba(255,0,0,0.2); }
        .terminal-container.active { display: block; }
        .term-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); padding-bottom: 6px; margin-bottom: 10px; font-size: 0.8rem; color: var(--danger); }
        .term-close { cursor: pointer; }

        /* 🛑 聲明與政治壓迫感橫幅 */
        .alert-banner { background: #0c0505; border: 2px solid var(--danger); padding: 18px; box-shadow: 0 0 15px rgba(255,0,0,0.1); }
        .alert-title { color: var(--danger); font-weight: bold; font-size: 1.2rem; margin-bottom: 10px; text-shadow: 0 0 5px rgba(255,0,0,0.5); }
        .crypto-address-box { background-color: #020202; border: 1px dashed var(--danger); padding: 10px; margin-top: 12px; }
        .tab-btn { background: transparent; border: 1px solid var(--border); color: var(--text-main); padding: 4px 10px; font-size: 0.8rem; cursor: pointer; font-family: 'Share Tech Mono', monospace; }
        .tab-btn.active { border-color: var(--danger); color: var(--danger); background: rgba(255,0,51,0.05); }

        /* 🪆 普丁大頭照與克格勃最高意志控制底層 */
        .kgb-footer {
            margin-top: 40px; display: flex; flex-direction: column; align-items: center;
            justify-content: center; gap: 15px; border-top: 2px dashed var(--border); padding-top: 25px;
            text-align: center; background: linear-gradient(to top, #060b07, transparent);
        }
        .putin-avatar {
            width: 140px; height: 180px; object-fit: cover;
            border: 3px solid var(--border); box-shadow: var(--neon-glow);
            filter: grayscale(40%) contrast(120%) sepia(20%); /* 復古冷戰軍用照片濾鏡 */
            transition: all 0.5s;
        }
        .putin-avatar:hover {
            border-color: var(--danger); box-shadow: 0 0 20px rgba(255,0,51,0.6);
            filter: grayscale(0%) contrast(130%);
        }
        .kgb-stamp {
            color: var(--danger); font-size: 1.1rem; font-weight: bold;
            text-shadow: 0 0 5px rgba(255,0,0,0.5); letter-spacing: 2px;
        }

        .toast-msg { position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%); background-color: var(--danger); color: black; font-weight:bold; padding: 8px 20px; border: 2px solid #fff; font-size: 0.9rem; display: none; z-index: 1000; }
    </style>
</head>
<body>

